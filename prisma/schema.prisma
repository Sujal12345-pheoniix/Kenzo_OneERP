datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// PRIORITY 02 — PRISMA ENUM DEFINITIONS
// ==========================================

enum UserRoleType {
  SUPER_ADMIN
  COMPANY_ADMIN
  CEO
  CTO
  HR
  FINANCE
  PROJECT_MANAGER
  DEVELOPER
  SUPPORT_AGENT
  EMPLOYEE
}

enum EmployeeDepartment {
  ENGINEERING
  SALES
  HR
  FINANCE
  SUPPORT
  MANAGEMENT
  ADMINISTRATION
  MARKETING
  OPERATIONS
}

enum EmployeeStatus {
  ACTIVE
  ONBOARDING
  ON_LEAVE
  INACTIVE
  TERMINATED
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  LEAVE
}

enum LeaveType {
  SICK
  CASUAL
  ANNUAL
  UNPAID
  MATERNITY
  PATERNITY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
  WON
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum ExpenseCategory {
  TRAVEL
  SOFTWARE
  OFFICE
  MARKETING
  SALARY
  UTILITIES
  OTHER
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssetType {
  LAPTOP
  SERVER
  LICENSE
  FURNITURE
  VEHICLE
  EQUIPMENT
}

enum AssetStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  APPROVE
  REJECT
}

enum AuditResource {
  TENANT
  USER
  ROLE
  PERMISSION
  EMPLOYEE
  ATTENDANCE
  LEAVE
  PROJECT
  TASK
  LEAD
  INVOICE
  EXPENSE
  ASSET
  NOTICES
}

enum ActivityType {
  PROJECT
  FINANCE
  HR
  LEAD
  SECURITY
  SYSTEM
  NOTICE
}

// ==========================================
// PRIORITY 01 — ENTERPRISE RBAC MODELS
// ==========================================

model Role {
  id          String       @id @default(uuid())
  tenantId    String?
  tenant      Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  code        UserRoleType
  description String?
  isSystem    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
}

model Permission {
  id          String        @id @default(uuid())
  code        String        @unique // e.g. "employee:create", "invoice:delete", "employee:salary:view"
  module      String        // e.g. "HR", "FINANCE", "PROJECTS", "CRM", "ADMIN"
  resource    AuditResource
  action      AuditAction
  description String
  createdAt   DateTime      @default(now())

  rolePermissions RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
}

// ==========================================
// CORE DOMAIN MODELS (DECIMAL & SOFT DELETE)
// ==========================================

model Tenant {
  id        String   @id @default(uuid())
  name      String
  domain    String   @unique
  settings  Json?
  
  // Priority 04: Soft Delete
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  deletedBy      String?
  deletionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  roles       Role[]
  employees   Employee[]
  attendances Attendance[]
  leaves      Leave[]
  projects    Project[]
  tasks       Task[]
  leads       Lead[]
  invoices    Invoice[]
  expenses    Expense[]
  assets      Asset[]
  auditLogs   AuditLog[]
  activities  Activity[]
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String
  name         String
  role         UserRoleType @default(EMPLOYEE)
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Priority 04: Soft Delete
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  deletedBy      String?
  deletionReason String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userRoles  UserRole[]
  employee   Employee?
  auditLogs  AuditLog[]
}

model Employee {
  id           String             @id @default(uuid())
  tenantId     String
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String?            @unique
  user         User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  firstName    String
  lastName     String
  department   EmployeeDepartment @default(ENGINEERING)
  position     String
  status       EmployeeStatus     @default(ACTIVE)
  salary       Decimal            @db.Decimal(12, 2) // Priority 03: Precision Money
  hireDate     DateTime           @default(now())

  // Priority 04: Soft Delete
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  deletedBy      String?
  deletionReason String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attendances Attendance[]
  leaves      Leave[]
  tasks       Task[]
  assets      Asset[]
}

model Attendance {
  id         String           @id @default(uuid())
  tenantId   String
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime         @db.Date
  checkIn    DateTime?
  checkOut   DateTime?
  status     AttendanceStatus @default(PRESENT)

  // Priority 04: Soft Delete
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  deletedBy      String?
  deletionReason String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([employeeId, date])
}

model Leave {
  id         String      @id @default(uuid())
  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startDate  DateTime
  endDate    DateTime
  type       LeaveType   @default(CASUAL)
  status     LeaveStatus @default(PENDING)
  reason     String

  // Priority 04: Soft Delete
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  deletedBy      String?
  deletionReason String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Project {
  id          String        @id @default(uuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime
  endDate     DateTime?
  budget      Decimal       @db.Decimal(12, 2) // Priority 03: Precision Money

  // Priority 04: Soft Delete
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  deletedBy      String?
  deletionReason String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tasks       Task[]
}

model Task {
  id          String       @id @default(uuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  assigneeId  String?
  assignee    Employee?    @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  dueDate     DateTime?

  // Priority 04: Soft Delete
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  deletedBy      String?
  deletionReason String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Lead {
  id        String     @id @default(uuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  company   String
  email     String
  status    LeadStatus @default(NEW)
  value     Decimal    @db.Decimal(12, 2) // Priority 03: Precision Money
  notes     String?

  // Priority 04: Soft Delete
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  deletedBy      String?
  deletionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id           String        @id @default(uuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceNo    String
  customerName String
  amount       Decimal       @db.Decimal(12, 2) // Priority 03: Precision Money
  status       InvoiceStatus @default(DRAFT)
  issueDate    DateTime      @default(now())
  dueDate      DateTime

  // Priority 04: Soft Delete
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  deletedBy      String?
  deletionReason String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Expense {
  id          String          @id @default(uuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category    ExpenseCategory @default(OTHER)
  amount      Decimal         @db.Decimal(12, 2) // Priority 03: Precision Money
  status      ExpenseStatus   @default(PENDING)
  date        DateTime
  description String
  approvedBy  String?

  // Priority 04: Soft Delete
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  deletedBy      String?
  deletionReason String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Asset {
  id           String      @id @default(uuid())
  tenantId     String
  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  type         AssetType   @default(LAPTOP)
  serialNumber String
  status       AssetStatus @default(ACTIVE)
  assignedToId String?
  assignedTo   Employee?   @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  // Priority 04: Soft Delete
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  deletedBy      String?
  deletionReason String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model AuditLog {
  id        String        @id @default(uuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    AuditAction   @default(READ)
  resource  AuditResource @default(TENANT)
  details   String
  timestamp DateTime      @default(now())
}

model Activity {
  id        String       @id @default(uuid())
  tenantId  String
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  message   String
  type      ActivityType @default(SYSTEM)
  timestamp DateTime     @default(now())
}
